# Shared constants for GitHub workflows and repository automation.

# Rust toolchain versions

# used for testing, ensures the MSRV promise is kept; must match Cargo.toml [package].rust-version
RUST_MSRV=1.95.0
# used for static analysis & mutation testing; must match rust-toolchain.toml
RUST_LATEST=1.95.0
# used for coverage and extended analysis; update on a regular basis
RUST_NIGHTLY=nightly-2026-01-21

# Cargo tools
CARGO_CAREFUL_VERSION=0.4.10
CARGO_DENY_VERSION=0.19.4
CARGO_ENSURE_NO_DEFAULT_FEATURES_VERSION=1.1.0
CARGO_LLVM_COV_VERSION=0.8.5
CARGO_MUTANTS_VERSION=27.0.0
CARGO_NEXTEST_VERSION=0.9.133
CARGO_SORT_VERSION=2.1.4
CARGO_SPELLCHECK_VERSION=0.15.1
CARGO_RDME_VERSION=1.5.0
CARGO_UDEPS_VERSION=0.1.60

# Other tools
SCCACHE_VERSION=v0.13.0
